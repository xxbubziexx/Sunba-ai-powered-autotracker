# Coral Edge TPU USB — disable autosuspend on both DFU and runtime USB IDs.
# Install on the PROXMOX HOST (not inside the VM):
#   sudo cp 99-coral-usb.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
# Then unplug/replug the Coral.

# DFU mode (initial plug-in, before firmware loads)
SUBSYSTEM=="usb", ATTRS{idVendor}=="1a6e", ATTRS{idProduct}=="089a", \
    ATTR{power/control}="on", ATTR{power/autosuspend_delay_ms}="0"

# Runtime mode (after libedgetpu loads firmware)
SUBSYSTEM=="usb", ATTRS{idVendor}=="18d1", ATTRS{idProduct}=="9302", \
    ATTR{power/control}="on", ATTR{power/autosuspend_delay_ms}="0"
